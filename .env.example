# PreventX environment variables
# Copy to .env.local and replace placeholders with real values.

# Supabase
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# NVIDIA NIM API key (used by src/lib/ai.ts via Vite proxy)
VITE_NVIDIA_API_KEY="your-nvidia-api-key"

# Optional legacy variable kept for compatibility with existing Vite define block
GEMINI_API_KEY="optional"

# Optional dev toggle
DISABLE_HMR="false"
