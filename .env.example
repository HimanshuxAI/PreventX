# PreventX environment variables
# Copy to .env.local and replace placeholders with real values.

# Required: NVIDIA key for server proxy and dev Vite proxy.
NVIDIA_API_KEY="your-nvidia-api-key"

# Required: Supabase public client config.
# Vite supports either prefix now. Use one set consistently.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
# NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# Optional: enable service worker only if you intentionally want offline caching.
VITE_ENABLE_SERVICE_WORKER="false"

# Optional legacy variable kept for compatibility with existing Vite define block.
GEMINI_API_KEY="optional"

# Optional dev toggle for environments where HMR causes instability.
DISABLE_HMR="false"
