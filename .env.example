# Required for AI chat proxying (server-side).
NVIDIA_API_KEY="YOUR_NVIDIA_API_KEY"

# Required: Supabase client configuration (public values).
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_public_anon_key"

# Optional: keep disabled unless you intentionally want offline caching.
VITE_ENABLE_SERVICE_WORKER="false"
